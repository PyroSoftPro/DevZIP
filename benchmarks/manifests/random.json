{
  "name": "random",
  "description": "High-entropy random binary data (worst case for compression).",
  "goal": {
    "baseline_tool": "7z-lzma2",
    "shipping_tool": "devzip-native"
  },
  "scoring": { "weissman": { "enabled": true, "baseline": "gzip", "alpha": 1.0 } },
  "datasets": [
    {
      "id": "random-entropy",
      "label": "Random binary data (5 files, ~10 MB)",
      "path": "sample-data/benchmarks/random-entropy",
      "tags": ["binary", "random", "high-entropy"]
    }
  ],
  "tools": {
    "devzip-native": {
      "command": ["powershell","-ExecutionPolicy","Bypass","-File","{project_root}\\benchmarks\\tools\\run_devzip_native.ps1","-InputPath","{input}","-OutputPath","{output}"],
      "output_extension": ".dvz"
    },
    "7z-lzma2": {
      "command": ["powershell","-ExecutionPolicy","Bypass","-File","{project_root}\\benchmarks\\tools\\run_7zip_max.ps1","-Method","lzma2","-InputPath","{input}","-OutputPath","{output}"],
      "output_extension": ".7z"
    },
    "7z-ppmd": {
      "command": ["powershell","-ExecutionPolicy","Bypass","-File","{project_root}\\benchmarks\\tools\\run_7zip_max.ps1","-Method","ppmd","-InputPath","{input}","-OutputPath","{output}"],
      "output_extension": ".7z"
    },
    "7z-bzip2": {
      "command": ["powershell","-ExecutionPolicy","Bypass","-File","{project_root}\\benchmarks\\tools\\run_7zip_max.ps1","-Method","bzip2","-InputPath","{input}","-OutputPath","{output}"],
      "output_extension": ".7z"
    },
    "7z-deflate": {
      "command": ["powershell","-ExecutionPolicy","Bypass","-File","{project_root}\\benchmarks\\tools\\run_7zip_max.ps1","-Method","deflate","-InputPath","{input}","-OutputPath","{output}"],
      "output_extension": ".7z"
    },
    "winrar": {
      "command": ["powershell","-ExecutionPolicy","Bypass","-File","{project_root}\\benchmarks\\tools\\run_winrar_max.ps1","-InputPath","{input}","-OutputPath","{output}"],
      "output_extension": ".rar"
    },
    "windows-zip": {
      "command": ["powershell","-ExecutionPolicy","Bypass","-File","{project_root}\\benchmarks\\tools\\run_windows_zip.ps1","-InputPath","{input}","-OutputPath","{output}"],
      "output_extension": ".zip"
    }
  }
}
