{
  "name": "mixed-large",
  "description": "Representative Windows ratio benchmark matrix for DevZip and desktop archivers.",
  "goal": {
    "aggregate_minimum_win_percent_vs_7z": 10.0,
    "baseline_tool": "7z-lzma2",
    "shipping_tool": "devzip-native",
    "shipping_backend": "lzma2"
  },
  "scoring": {
    "weissman": {
      "enabled": true,
      "baseline": "gzip",
      "alpha": 1.0
    }
  },
  "datasets": [
    {
      "id": "nato",
      "label": "Small text corpus",
      "path": "sample-data/wcDogg-test-files/nato",
      "tags": ["text", "small"]
    },
    {
      "id": "native-src",
      "label": "Native engine source tree",
      "path": "native/engine/src",
      "tags": ["code", "text", "repetition"]
    },
    {
      "id": "PngSuite",
      "label": "Small image suite",
      "path": "sample-data/wcDogg-test-files/PngSuite",
      "tags": ["image", "binary", "precompressed"]
    },
    {
      "id": "wcDogg",
      "label": "Large image-heavy corpus",
      "path": "sample-data/wcDogg-test-files/wcDogg",
      "tags": ["image", "binary", "precompressed", "large"]
    }
  ],
  "tools": {
    "devzip-native": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_devzip_native.ps1",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".dvz"
    },
    "7z-lzma2": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_7zip_max.ps1",
        "-Method",
        "lzma2",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".7z"
    },
    "7z-lzma": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_7zip_max.ps1",
        "-Method",
        "lzma",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".7z"
    },
    "7z-ppmd": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_7zip_max.ps1",
        "-Method",
        "ppmd",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".7z"
    },
    "7z-bzip2": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_7zip_max.ps1",
        "-Method",
        "bzip2",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".7z"
    },
    "7z-deflate": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_7zip_max.ps1",
        "-Method",
        "deflate",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".7z"
    },
    "winrar": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_winrar_max.ps1",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".rar"
    },
    "windows-zip": {
      "command": [
        "powershell",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{project_root}\\benchmarks\\tools\\run_windows_zip.ps1",
        "-InputPath",
        "{input}",
        "-OutputPath",
        "{output}"
      ],
      "output_extension": ".zip"
    }
  }
}
