<Window x:Class="DevZip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevZip"
        Width="900"
        Height="620"
        MinWidth="760"
        MinHeight="520"
        Background="#0D1117"
        Foreground="#F5F7FA"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style x:Key="DropSurfaceStyle" TargetType="Border">
      <Setter Property="Background" Value="#111827" />
      <Setter Property="BorderBrush" Value="#2B3A55" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="CornerRadius" Value="28" />
      <Setter Property="Padding" Value="32" />
      <Setter Property="Margin" Value="0,24,0,24" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="24"
                            ShadowDepth="0"
                            Color="#000000"
                            Opacity="0.25" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsDragOver}" Value="True">
          <Setter Property="Background" Value="#152236" />
          <Setter Property="BorderBrush" Value="#72C4FF" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsBusy}" Value="True">
          <Setter Property="BorderBrush" Value="#7DD3FC" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="Button">
      <Setter Property="Background" Value="#172235" />
      <Setter Property="Foreground" Value="#F5F7FA" />
      <Setter Property="BorderBrush" Value="#2F425F" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="14">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#21304A" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.45" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Margin="40">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock FontSize="32"
                 FontWeight="SemiBold"
                 Text="DevZip" />
      <TextBlock Margin="0,8,0,0"
                 FontSize="15"
                 Foreground="#B3C0D1"
                 Text="Drop one file or folder into the zone below and compression starts immediately." />
    </StackPanel>

    <Border Grid.Row="1"
            Style="{StaticResource DropSurfaceStyle}"
            AllowDrop="True"
            DragEnter="DropSurface_DragEnter"
            DragOver="DropSurface_DragOver"
            DragLeave="DropSurface_DragLeave"
            Drop="DropSurface_Drop">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel VerticalAlignment="Center">
          <TextBlock HorizontalAlignment="Center"
                     FontSize="18"
                     Foreground="#89A3C4"
                     Text="ARCHIVE TARGET" />
          <TextBlock Margin="0,18,0,0"
                     HorizontalAlignment="Center"
                     FontSize="42"
                     FontWeight="SemiBold"
                     TextAlignment="Center"
                     Text="Drop File Or Folder" />
          <TextBlock Margin="0,14,0,0"
                     HorizontalAlignment="Center"
                     FontSize="16"
                     Foreground="#B3C0D1"
                     TextAlignment="Center"
                     Text="{Binding DropHint}" />
        </StackPanel>

        <StackPanel Grid.Row="1">
          <ProgressBar Height="10"
                       Margin="0,0,0,18"
                       Maximum="100"
                       Value="{Binding ProgressValue, Mode=OneWay}"
                       Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
          <TextBlock FontSize="20"
                     FontWeight="SemiBold"
                     Text="{Binding StatusHeadline}" />
          <TextBlock Margin="0,8,0,0"
                     FontSize="14"
                     Foreground="#B3C0D1"
                     Text="{Binding StatusDetail}" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,28,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock FontSize="12"
                       Foreground="#7E92AF"
                       Text="Output archive" />
            <TextBlock Margin="0,4,0,0"
                       FontSize="14"
                       Text="{Binding OutputPath}"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right">
            <Button Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    IsEnabled="{Binding CanCancel}"
                    Content="Cancel" />
            <Button Click="OpenOutputButton_Click"
                    IsEnabled="{Binding CanOpenOutputFolder}"
                    Content="Open Folder" />
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <TextBlock Grid.Row="2"
               FontSize="13"
               Foreground="#7E92AF"
               Text="Compression expects the native CLI. Set DEVZIP_USE_REFERENCE_CODEC=1 only for explicit development fallback testing." />
  </Grid>
</Window>
